# Copy this file to .env and fill in your values
# .env is gitignored and should never be committed

# --- LLM Backend ---
# Set to "openrouter" to use OpenRouter API, or "ollama" to use your local fine-tuned model
LLM_BACKEND=openrouter

# --- OpenRouter (used when LLM_BACKEND=openrouter) ---
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Ollama (used when LLM_BACKEND=ollama) ---
# Make sure Ollama is running locally: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5
