# Copy this file to .env and fill in your values
# .env is gitignored and should never be committed

# ── Provider selection ────────────────────────────────────────
# "openrouter"  cloud API, any model (default dev setup)
# "ollama"      local Ollama server with GGUF model
# "vllm"        cloud vLLM server (production)
LLM_PROVIDER=openrouter

# ── OpenRouter (LLM_PROVIDER=openrouter) ─────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
MODEL_NAME=openai/gpt-4o-mini
# BASE_URL defaults to https://openrouter.ai/api/v1 — no need to set unless changing

# ── Ollama (LLM_PROVIDER=ollama) ─────────────────────────────
# Requires: ollama serve + model registered via ollama create
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen-emotional-coach

# ── vLLM (LLM_PROVIDER=vllm) — production ────────────────────
# VLLM_BASE_URL=https://YOUR-POD-ID-8000.proxy.runpod.net/v1
# VLLM_API_KEY=your-vllm-token
# VLLM_MODEL=yourname/qwen-emotional-coach-merged

# ── App ───────────────────────────────────────────────────────
# API_BASE_URL=http://127.0.0.1:8000   # override in Docker/production
# DB_PATH=chatbot.db                   # override to /data/chatbot.db in Docker

# ── Training / data pipeline (not needed for running the app) ─
WANDB_API_KEY=your_wandb_api_key_here
HF_TOKEN=your_huggingface_token_here
